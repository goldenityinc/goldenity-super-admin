{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "destination": "/admin/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://goldenity-admin-core-backend-production.up.railway.app/api/$1"
    },
    {
      "source": "/admin/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/admin/logo.png",
      "destination": "/logo.png"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/index.html"
    }
  ]
}
